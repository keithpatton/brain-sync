# Auto-normalize line endings: LF in repo, native on checkout
* text=auto

# Force LF for source files (consistent across Windows/macOS)
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf

# Windows-specific files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
